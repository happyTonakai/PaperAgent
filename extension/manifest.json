{
  "manifest_version": 3,
  "name": "PaperAgent",
  "version": "1.1.0",
  "description": "一键在 PaperAgent 中打开 arXiv 论文",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": ["http://localhost/*"],
  "content_scripts": [
    {
      "matches": [
        "https://arxiv.org/abs/*",
        "https://arxiv.org/pdf/*",
        "https://www.arxiv.org/abs/*",
        "https://www.arxiv.org/pdf/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  }
}
